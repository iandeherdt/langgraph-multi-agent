# ─── Required: API keys ────────────────────────────────────────────────────────

# Anthropic — used for the planner AND the completion advisor (verify_completion).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI-compatible — defaults to OpenRouter for the builder + evaluator.
# Replace with a llama.cpp/Ollama URL + dummy key for fully-local runs (see bottom).
OPENAI_API_KEY=sk-or-v1-your-key-here


# ─── Models ────────────────────────────────────────────────────────────────────

# Anthropic model IDs (planner + advisor). The advisor is the second-opinion check
# on builder claims before mark_done — keep it strong; don't downgrade to Haiku.
PLANNER_MODEL=claude-sonnet-4-6
ADVISOR_MODEL=claude-sonnet-4-6

# OpenRouter slugs. Builder drives the work; evaluator browses the result via
# Playwright MCP and emits a verdict. EVAL_MODEL must be vision-capable (it
# interprets screenshots).
BUILDER_MODEL=qwen/qwen3-coder-next
EVAL_MODEL=qwen/qwen3.6-27b


# ─── Endpoints ─────────────────────────────────────────────────────────────────

OPENAI_BASE_URL=https://openrouter.ai/api/v1

# MCP server SSE URL. Default points at the sibling docker-compose service; only
# override if you're running playwright-mcp somewhere else.
# PLAYWRIGHT_MCP_URL=http://playwright-mcp:8931/sse


# ─── OpenRouter provider routing ───────────────────────────────────────────────
# OpenRouter sometimes routes a tool-calling request to a provider whose response
# format the OpenAI shim can't parse (you'll see broken / empty tool calls in the
# trace). Two ways to fix it:

# Pin to specific providers in priority order (disables fallbacks entirely).
# Find which providers actually work in your OpenRouter activity log.
# OPENROUTER_PROVIDERS=fireworks,deepinfra

# OR exclude one bad provider without pinning everything (other providers still
# tried via fallbacks). Cheaper to maintain than a full pin.
# OPENROUTER_IGNORE_PROVIDERS=parasail


# ─── Cost display ──────────────────────────────────────────────────────────────

# Render running totals in EUR (default) or USD. The pricing table itself is in
# USD; EUR uses an internal COST_USD_TO_EUR=0.92 factor.
# HARNESS_COST_CCY=EUR


# ─── Streaming + retry ─────────────────────────────────────────────────────────

# Per-chunk timeout for model streams. OpenRouter sometimes accepts a request and
# stops sending chunks; the default langchain timeout (120s) compounds across the
# 3 model retries. 60s catches stuck streams faster.
# STREAM_CHUNK_TIMEOUT_SECONDS=60


# ─── Long-run features (defaults are sensible; override only when needed) ─────

# Per-iteration git checkpoints to a per-run branch (`harness-run-<UTC>`). Set
# 0 to disable; the workspace stays uncheckpointed.
# HARNESS_GIT_CHECKPOINTS=1

# Persist state.json per iteration; surface in-progress runs on fresh startup;
# enable `./run.sh --resume <run-id>`. Set 0 for stateless / CI use.
# RESUME_ENABLED=1

# Skip browser eval on iterations that touched no UI files (server-side fixes,
# config tweaks, etc.). Saves ~50 MCP tool calls / iter when applicable.
# EVAL_SKIP_ENABLED=1


# ─── MCP transport recovery ────────────────────────────────────────────────────
# When the persistent SSE session drops mid-eval (peer disconnect, network blip,
# OOM in playwright-mcp), reconnect with exponential backoff before giving up.

# MCP_RECOVERY_ENABLED=1
# MCP_RECOVERY_WAIT_SECONDS=10           # initial backoff; doubled per retry
# MCP_RECOVERY_MAX_RETRIES=3             # 10s + 20s + 40s of recovery effort total


# ─── Test gate ─────────────────────────────────────────────────────────────────
# Run a test command between successful eval and git checkpoint. Iterations that
# regress tests don't get committed; the builder is sent back with the failure
# output. After N consecutive failures the run terminates (circuit breaker).
# Empty HARNESS_TEST_COMMAND disables the feature entirely — existing runs on
# projects without test suites work unchanged.

# HARNESS_TEST_COMMAND=cd agency-cms && npm run test
# HARNESS_TEST_CWD=/workspace             # cwd for the command; or `cd <subdir> &&` in the cmd
# HARNESS_TEST_TIMEOUT_SECONDS=120
# HARNESS_TEST_GATE_REQUIRED=1            # 0 → warnings-only mode (commit despite failures)
# HARNESS_TEST_GATE_MAX_STREAK=3          # consecutive failures before circuit breaker
# HARNESS_TEST_OUTPUT_TAIL_LINES=50


# ─── Git commit attribution (per-iteration commits to harness-run-<UTC> branch) ─
# Defaults: harness <harness@local>. Override if you want commits attributed to
# a real identity for downstream review tooling.
# GIT_AUTHOR_NAME=harness
# GIT_AUTHOR_EMAIL=harness@local
# GIT_COMMITTER_NAME=harness
# GIT_COMMITTER_EMAIL=harness@local


# ─── Local llama.cpp alternative ───────────────────────────────────────────────
# Start the local model with: docker compose --profile local up -d llama-cpp
# Then swap the OPENAI_* values above for the values below. Anthropic still hits
# the planner + advisor — there's no local alternative for those yet.
# OPENAI_BASE_URL=http://llama-cpp:8080/v1
# OPENAI_API_KEY=sk-no-key-required
# BUILDER_MODEL=qwen3.6
# EVAL_MODEL=qwen3.6
