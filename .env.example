# Planner — Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
PLANNER_MODEL=claude-sonnet-4-6

# Builder + Evaluator — OpenAI-compatible (OpenRouter by default)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-your-key-here
BUILDER_MODEL=qwen/qwen3-coder-next
EVAL_MODEL=qwen/qwen3.6-27b

# Optional OpenRouter provider routing.
# Pin to specific providers in priority order (disables fallbacks):
# OPENROUTER_PROVIDERS=fireworks,deepinfra
# Exclude unreliable providers without pinning (other providers still tried via fallbacks):
# OPENROUTER_IGNORE_PROVIDERS=parasail

# Playwright MCP (defaults to the sibling container)
# PLAYWRIGHT_MCP_URL=http://playwright-mcp:8931/sse

# --- Local llama.cpp alternative (start with: docker compose --profile local up -d llama-cpp) ---
# OPENAI_BASE_URL=http://llama-cpp:8080/v1
# OPENAI_API_KEY=sk-no-key-required
# BUILDER_MODEL=qwen3.6
# EVAL_MODEL=qwen3.6
