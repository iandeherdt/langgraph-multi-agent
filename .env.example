# Pick ONE provider block. The graph reads OPENAI_BASE_URL + OPENAI_API_KEY + MODEL.

# --- OpenRouter (cloud) ---
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-your-key-here
MODEL=openai/gpt-4o-mini

